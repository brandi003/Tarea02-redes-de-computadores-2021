link l6 {
    nodes {n8 n3}
    bandwidth 0
}

link l7 {
    nodes {n8 n7}
    bandwidth 0
}

link l0 {
    nodes {n3 n0}
    bandwidth 0
}

link l1 {
    nodes {n3 n1}
    bandwidth 0
}

link l2 {
    nodes {n3 n2}
    bandwidth 0
}

link l3 {
    nodes {n7 n4}
    bandwidth 0
}

link l4 {
    nodes {n5 n7}
    bandwidth 0
}

link l5 {
    nodes {n6 n7}
    bandwidth 0
}

canvas c0 {
    name {Canvas0}
    size {1200 700}
}

option show {
    interface_names yes
    ip_addresses yes
    ipv6_addresses no
    node_labels yes
    link_labels yes
    background_images no
    annotations yes
    hostsAutoAssign no
    grid yes
    iconSize normal
    zoom 1.0
}

